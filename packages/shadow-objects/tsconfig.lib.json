{
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts", "src/**/*.js"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/**/*.specs.ts"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/src",
    "declarationDir": "./dist/src",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": false,
    "importHelpers": false,
    "noEmit": false,
    "incremental": false,
    "composite": false
  }
}